            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@focusforest.com\",\n  \"password\": \"Test1234!\",\n  \"name\": \"Test User\",\n  \"utcOffset\": 330\n}"
            },

          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const status = pm.response.code;",
                  "const body = pm.response.json();",
                  "pm.test('Status is 201 or 409', () => pm.expect([201, 409]).to.include(status));",
                  "if (status === 201) {",
                  "  pm.collectionVariables.set('jwt', body.accessToken);",
                  "  pm.collectionVariables.set('userId', body.user.id);",
